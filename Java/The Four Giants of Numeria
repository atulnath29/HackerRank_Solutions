/*
In the land of Numeria, four mighty giants guard the four directions: • North Giant 🧊 • South Giant 🔥 • East Giant 🌪️ • West Giant 🌊

Each giant has a strength value represented by an integer. The king of Numeria wants to know who is the second strongest giant — the one who stands just below the mightiest giant.

⸻

⚔️ Your Task:

You are given four integers (the strengths of the four giants). • Without using arrays or sorting, determine the second largest strength. • You are allowed to use max() and min() functions to solve this.

Input Format

• A single line containing four space-separated integers:

Constraints

Input always contains exactly 4 integers. • -10⁴ ≤ A, B, C, D ≤ 10⁴

Output Format

Print a single integer → the second largest number.

Sample Input 0

5 10 15 20
Sample Output 0

15
Sample Input 1

2 1 3 4
Sample Output 1

3
*/

import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      Scanner sc = new Scanner(System.in);
      int a = sc.nextInt();
      int b = sc.nextInt();
      int c = sc.nextInt();
      int d = sc.nextInt();
      int sm = 0;
      int max = Math.max(Math.max(Math.max(a, b),c),d);
      int min = Math.min(Math.min(Math.min(a, b),c),d);
      if ( a != max && a != min){
        sm = Math.max(sm, a);
      }
      if ( b != max && b != min){
        sm = Math.max(sm, b);
      }
      if ( c != max && c != min){
        sm = Math.max(sm, c);
      }
      if ( d != max && d != min){
        sm = Math.max(sm, d);
      }
      System.out.print(sm);
    }
}
